{
    "$schema": "https://schemas.wp.org/wp/6.5/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "color": {
            "palette": [
                { "slug": "aqua-doux",   "color": "#7dd3c7", "name": "Aqua doux" },
                { "slug": "ocre-renard", "color": "#c77936", "name": "Ocre renard" },
                { "slug": "terracotta",  "color": "#8B3A0E", "name": "Terracotta" },
                { "slug": "creme",       "color": "#F7EFE2", "name": "Creme" },
                { "slug": "nuit",        "color": "#060B10", "name": "Nuit profonde" },
                { "slug": "surface",     "color": "#0B1416", "name": "Surface" },
                { "slug": "light-text",  "color": "#DCE7E2", "name": "Texte clair" },
                { "slug": "heading",     "color": "#FFF7EB", "name": "Titre" }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "'Space Grotesk', system-ui, sans-serif",
                    "slug": "heading",
                    "name": "Space Grotesk"
                },
                {
                    "fontFamily": "'Outfit', system-ui, sans-serif",
                    "slug": "body",
                    "name": "Outfit"
                }
            ]
        },
        "spacing": {
            "units": ["px", "rem", "vh", "vw", "%"]
        },
        "layout": {
            "contentSize": "800px",
            "wideSize": "1200px"
        }
    },
    "styles": {
        "color": {
            "background": "#060B10",
            "text": "#DCE7E2"
        },
        "typography": {
            "fontFamily": "'Outfit', system-ui, sans-serif"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "'Space Grotesk', system-ui, sans-serif"
                },
                "color": {
                    "text": "#FFF7EB"
                }
            },
            "link": {
                "color": {
                    "text": "#7dd3c7"
                }
            }
        }
    }
}
